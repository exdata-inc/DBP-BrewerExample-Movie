# Kintone連携（オプション）
# 動画醸造ログをKintoneにプッシュする場合のみ設定する。
# 3つすべてが設定されている場合に有効化され、未設定ならプッシュは自動的にスキップされる。
# レコード構造は dbp-video-brewer(TRUSCO) と同一。

KINTONE_SUBDOMAIN=your-subdomain
KINTONE_APP_ID=123
KINTONE_API_TOKEN=your-api-token

# 醸造需要JSON-LDで push_kintone を指定しない場合でも、
# この環境変数を有効にすればログ送信を強制できる（1 / true / yes / on）。
# KINTONE_PUSH_LOG=1

# レコードのキーとなる拠点(depo)。醸造引数 depo が優先され、無い場合にこの値を使う。
# KINTONE_DEPO=p_tokai


# Slack連携（オプション）
# 動画醸造の進捗・結果をSlackに通知する場合のみ設定する。
# 2つとも設定されている場合に有効化され、未設定なら通知は自動的にスキップされる。

# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL=C0XXXXXXXXX

# 醸造需要JSON-LDで push_slack を指定しない場合でも、
# この環境変数を有効にすれば通知を強制できる（1 / true / yes / on）。
# SLACK_NOTIFY=1
