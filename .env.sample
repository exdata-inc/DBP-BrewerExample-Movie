# Kintone連携（オプション）
# 下記3つがすべて設定されていれば、既定で動画醸造ログをKintoneに送信する。
# 未設定なら自動的にスキップされる。レコード構造は dbp-video-brewer(TRUSCO) と同一。

KINTONE_SUBDOMAIN=your-subdomain
KINTONE_APP_ID=123
KINTONE_API_TOKEN=your-api-token

# 明示的に有効化/無効化したい場合のみ指定する（1/true で送信、0/false で送信しない）。
# 醸造引数 push_kintone が優先。接続情報はあるが送りたくない場合は 0 を指定する。
# KINTONE_PUSH_LOG=1

# レコードのキーとなる拠点(depo)。醸造引数 depo が優先され、無い場合にこの値を使う。
# KINTONE_DEPO=p_tokai


# Slack連携（オプション）
# 下記2つがともに設定されていれば、既定で動画醸造の進捗・結果をSlackに通知する。
# 未設定なら自動的にスキップされる。

# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL=C0XXXXXXXXX

# 明示的に有効化/無効化したい場合のみ指定する（1/true で通知、0/false で通知しない）。
# 醸造引数 push_slack が優先。接続情報はあるが通知したくない場合は 0 を指定する。
# SLACK_NOTIFY=1
